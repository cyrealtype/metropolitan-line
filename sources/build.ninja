# instantiateUfo: Create instance UFOs from a Glyphs or designspace file
rule instantiateUfo
  command = /Users/alexeiva/venv/ftools/bin/python3 -m $
      gftools.builder.jobrunner fontmake -i "$instance_name" -o ufo $
      $fontmake_type $in $args $stamp
  description = instantiateUfo

# buildTTF: Build a TTF from a source file
rule buildTTF
  command = /Users/alexeiva/venv/ftools/bin/python3 -m $
      gftools.builder.jobrunner fontmake --output-path $out -o ttf $
      $fontmake_type $in $args $stamp
  description = buildTTF

# autohint: Run gftools-autohint
rule autohint
  command = /Users/alexeiva/venv/ftools/bin/python3 -m $
      gftools.builder.jobrunner gftools-autohint $args -o $out $in $stamp
  description = autohint

# fix: Run gftools-fix
rule fix
  command = /Users/alexeiva/venv/ftools/bin/python3 -m $
      gftools.builder.jobrunner gftools-fix-font -o $out $args $in $stamp
  description = fix

# compress: Compress to webfont
rule compress
  command = /Users/alexeiva/venv/ftools/bin/python3 -m $
      gftools.builder.jobrunner fonttools ttLib.woff2 compress -o $out $in $
      $stamp
  description = compress

# buildOTF: Build a OTF from a source file
rule buildOTF
  command = /Users/alexeiva/venv/ftools/bin/python3 -m $
      gftools.builder.jobrunner fontmake --output-path $out -o otf $
      $fontmake_type $in $args $stamp
  description = buildOTF

# copy: Copy a file
rule copy
  command = /Users/alexeiva/venv/ftools/bin/python3 -m $
      gftools.builder.jobrunner cp $in $out $stamp
  description = copy

# Generating instance_ufos/MetropolitanLine-Regular.ufo.json
build instance_ufos/MetropolitanLine-Regular.ufo.json: instantiateUfo $
    MetropolitanLine.glyphs
  operation = instantiateUfo
  instance_name = Metropolitan Line Regular
  fontmake_type = -g
  fontmake_args =  --verbose WARNING 
  args =  --ufo-structure=json --instance-dir instance_ufos
# Generating ../fonts/webfonts/MetropolitanLine-Regular.woff2
build ../fonts/webfonts/MetropolitanLine-Regular.woff2: compress $
    ../fonts/ttf/MetropolitanLine-Regular.ttf
  operation = compress
# Generating /var/folders/xm/8_gkzvmn2f30h2nxxfdh_n380000gp/T/tmpjvxnmobv
build /var/folders/xm/8_gkzvmn2f30h2nxxfdh_n380000gp/T/tmpjvxnmobv: $
    buildTTF instance_ufos/MetropolitanLine-Regular.ufo.json
  operation = buildTTF
  args = --filter ...  --filter FlattenComponentsFilter --filter $
      DecomposeTransformedComponentsFilter
  fontmake_type = -u
  fontmake_args =  --verbose WARNING 
# Generating /var/folders/xm/8_gkzvmn2f30h2nxxfdh_n380000gp/T/tmpq3xc_7k3
build /var/folders/xm/8_gkzvmn2f30h2nxxfdh_n380000gp/T/tmpq3xc_7k3: $
    buildOTF instance_ufos/MetropolitanLine-Regular.ufo.json
  operation = buildOTF
  args = --filter ...  --filter FlattenComponentsFilter --filter $
      DecomposeTransformedComponentsFilter
  fontmake_type = -u
  fontmake_args =  --verbose WARNING 
# Generating /var/folders/xm/8_gkzvmn2f30h2nxxfdh_n380000gp/T/tmpr4_in9bc
build /var/folders/xm/8_gkzvmn2f30h2nxxfdh_n380000gp/T/tmpr4_in9bc: $
    autohint /var/folders/xm/8_gkzvmn2f30h2nxxfdh_n380000gp/T/tmpjvxnmobv
  operation = autohint
  args = --fail-ok  --auto-script
# Generating ../fonts/ttf/MetropolitanLine-Regular.ttf
build ../fonts/ttf/MetropolitanLine-Regular.ttf: fix $
    /var/folders/xm/8_gkzvmn2f30h2nxxfdh_n380000gp/T/tmpr4_in9bc
  operation = fix
  args = 
# Generating ../fonts/otf/MetropolitanLine-Regular.otf
build ../fonts/otf/MetropolitanLine-Regular.otf: fix $
    /var/folders/xm/8_gkzvmn2f30h2nxxfdh_n380000gp/T/tmpq3xc_7k3
  operation = fix
  args = 
default ../fonts/webfonts/MetropolitanLine-Regular.woff2 $
    ../fonts/otf/MetropolitanLine-Regular.otf
